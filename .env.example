# OpenRouter configuration for AI Travel Agent
# -----------------------------------------------
# 1. Create a FREE account at https://openrouter.ai
# 2. Go to https://openrouter.ai/keys and generate an API key
# 3. Paste the key below (starts with sk-or-...)

OPENROUTER_API_KEY=sk-or-...

# Optional: override the default base URL (rarely needed)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: choose a specific model.
# Defaults to "openrouter/auto" which routes to the best free model automatically.
# Browse free models at https://openrouter.ai/models?free=true
# Examples:
#   OPENROUTER_MODEL=openrouter/auto
#   OPENROUTER_MODEL=meta-llama/llama-4-maverick:free
#   OPENROUTER_MODEL=google/gemma-3-27b-it:free
OPENROUTER_MODEL=openrouter/auto

# -----------------------------------------------
# Scraper settings (optional)
# -----------------------------------------------
SCRAPER_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36"
SCRAPER_TIMEOUT=15
SCRAPER_ENABLE_SELENIUM=true
